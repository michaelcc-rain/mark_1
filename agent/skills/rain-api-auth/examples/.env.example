# Rain API — example environment file.
# Copy to .env (which should be gitignored) and fill in your SANDBOX values.
# Never commit a real key. Never use a PRODUCTION key with an AI agent.

# Your sandbox API key value, from the Rain dashboard: Config > API Keys.
# The SDKs read this env var by default.
RAIN_API_KEY=your-sandbox-api-key-value

# Environment selector for the helper scripts in this skill:
#   dev         -> https://api-dev.raincards.xyz/v1   (sandbox, default)
#   production  -> https://api.raincards.xyz/v1        (live)
RAIN_ENV=dev

# Webhook signing key value (the dual-use key Rain uses to sign webhooks).
# By default this is the SAME as your tenant's auto-generated admin key, i.e.
# the same value as RAIN_API_KEY. If you created a dedicated webhookSigning-role
# key in the dashboard, set its value here instead.
RAIN_WEBHOOK_SIGNING_KEY=your-sandbox-api-key-value

# Optional: SDK debug logging. WARNING — exposes request/response data
# (cardholder PII, decrypted card details). Use only in development.
# RAIN_LOG=debug
